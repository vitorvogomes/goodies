# ============================================================
# Goodies — variáveis de ambiente (TEMPLATE PÚBLICO)
# ============================================================
# 1. Copie para `.env`:            cp .env.example .env
# 2. Preencha `.env` com valores reais (fica no .gitignore).
# 3. Ao adicionar uma chave aqui, adicione TAMBÉM em `.env`
#    (e vice-versa). Os dois arquivos devem ter SEMPRE as
#    mesmas chaves — só os valores diferem.
# Detalhes da política: .claude/memory/security.md
# ============================================================

# ---- App ----
ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# ---- Database (Supabase Postgres 15, asyncpg direto) ----
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# ---- Cache (Upstash Redis) ----
REDIS_URL=rediss://default:PASSWORD@HOST:PORT
UPSTASH_REDIS_REST_URL=https://YOUR-INSTANCE.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# ---- Auth JWT (ADR-006 — NÃO usar Supabase Auth) ----
# Gere segredos com: openssl rand -hex 32
JWT_SECRET_KEY=change_me_openssl_rand_hex_32
JWT_REFRESH_SECRET_KEY=change_me_another_random_hex_32
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
HERMES_SERVICE_TOKEN_SECRET=change_me_hermes_scope_secret
HERMES_TOKEN_TTL_DAYS=90

# ---- Market data APIs ----
BRAPI_TOKEN=your_brapi_token          # B3 — https://brapi.dev
COINGECKO_API_KEY=your_coingecko_key  # opcional no plano free
ETHERSCAN_API_KEY=your_etherscan_key  # ETH / ARB / HYPE
SOLSCAN_API_KEY=your_solscan_key      # SOL

# ---- Binance (cron only — signed HMAC-SHA256, nunca on-demand) ----
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# ---- Wallets (endereços de recebimento; privados por privacidade) ----
WALLET_EVM_ADDRESS=0xYOUR_EVM_ADDRESS      # ETH / ARB / HYPE (Etherscan)
WALLET_SOL_ADDRESS=YOUR_SOLANA_ADDRESS     # Solscan
WALLET_LIQUID_ADDRESS=YOUR_LIQUID_ADDRESS  # blockstream.info/liquid

# ---- Liquid Network (ADR-005) ----
LIQUID_BASE_URL=https://blockstream.info/liquid/api
# L-BTC asset id: constante pública (64 hex) da Liquid Network.
# Obtenha em https://blockstream.info/liquid ou nos docs do projeto e preencha no .env.
LBTC_ASSET_ID=

# ---- Notificações (m6) ----
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/CHANNEL_ID/TOKEN
